# =============================================================================
# UA Underwriting Agent — environment variables
# Copy to .env in the repo root:   Copy-Item .env.example .env
# Both the FastAPI backend and the Next.js app read this file.
# =============================================================================

# --- LLM provider for the UNDERWRITING PIPELINE ------------------------------
# One of: mock | anthropic | <your registered provider>
#   mock      = deterministic, no keys, no network. The FULL system works:
#               extraction returns synthetic ground truth; decisions, audit,
#               and replay are all real. This is the default and what CI uses.
#   anthropic = live extraction/narrative via the Anthropic API.
#               Requires ANTHROPIC_API_KEY.
# To add your own provider, see README "Bring your own LLM provider".
# NOTE (HR-1): the LLM NEVER makes credit decisions regardless of provider —
# it only extracts document fields, drafts condition wording, and narrates.
LLM_PROVIDER=mock

# Exact model id passed to the provider and pinned into every decision
# snapshot + audit event (HR-7). Ignored by mock.
LLM_MODEL=claude-sonnet-4-6

# Provider keys — only the one matching LLM_PROVIDER is required.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Underwriting policy -----------------------------------------------------
# Loans at/above this amount require a second reviewer (four-eyes), in
# addition to all declines which always require one (FR-DEC-4).
FOUR_EYES_THRESHOLD=1000000

# --- Backend ------------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO
# Stamped automatically by scripts/dev.ps1; pins the code version into
# decision snapshots for reproducibility audits.
CODE_GIT_SHA=

# --- Frontend -------------------------------------------------------------------
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
