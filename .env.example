# =============================================================================
# CopilotKit Kickstarter — environment variables
# Copy to .env in the repo root. Both the FastAPI backend and the Next.js
# runtime route read this file (next.config.js loads it via dotenv).
# =============================================================================

# --- LLM provider selection -------------------------------------------------
# One of: mock | openai | anthropic
#   mock      = page loads but chat won't return a model response
#               (use for first-load smoke and for evals).
#   openai    = real chat via OpenAIAdapter; needs OPENAI_API_KEY.
#   anthropic = real chat via AnthropicAdapter; needs ANTHROPIC_API_KEY.
LLM_PROVIDER=mock

# Model name passed to the provider. Examples:
#   openai:    gpt-4o-mini, gpt-4o
#   anthropic: claude-sonnet-4-6, claude-haiku-4-5-20251001
#   mock:      ignored
LLM_MODEL=gpt-4o-mini

# Provider keys — only the one matching LLM_PROVIDER is required.
# Read by the Next.js runtime route (for chat) and by the Python backend
# (for evals + future server-side agents).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Backend ----------------------------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# CORS origins for the FastAPI app (comma-separated).
CORS_ORIGINS=http://localhost:3000

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# --- Frontend ---------------------------------------------------------------
# URL the Next.js runtime route uses to call the Python backend.
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
